#!/bin/bash

## Usage:
#  updateall ["autowake-when"] ["seconds-delay"] ["update-skip"]
#
#  Ex:
#    updateall "tomorrow 04:00" 30 "yesOrAnythingOtherString"
#    updateall "tomorrow 04:00" 30 ""
#    updateall "tomorrow 04:00" 30
#    updateall "tomorrow 04:00"
#    updateall "+1 hour" 30
#    updateall
#
#  NOTES:
#    * It is best to set a delay when waking up or rebooting.
#    * Typically installed in /usr/bin
#
# v2026 06 14 003
#
