# Needed for some distro's
declare gTARGETS="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
declare gDIR=""
declare gTARGET=""

IFS=':'
for gDIR in $gTARGETS; do
  case ":$PATH:" in
    *":$gDIR:"*) ;;
    *) PATH="$PATH:$gDIR" ;;
  esac
done
unset IFS

# Get the directory of the running script
declare gSCRIPT_BRANCH="${BASH_SOURCE%/*}"

# Kill first script will be in same folder as updateall... may be string empty to ignore
# Targetted for users who don't close applications when they are finished when an update is available
# or those that want preflight action first e.g. arch updates which should never be included by default normally
declare gSCRIPT_PREFLIGHT="$gSCRIPT_BRANCH/updateallkillfirst"

##
declare gWAKEAT=""
declare gDELAY=""
declare gSKIPUD=""

declare gLOGGER_PATH="$(type -P logger)"

if [ "$EUID" -ne 0 ]; then
  exec sudo "$0" "$@"
    exit 1
else
  declare gNOHUP_PATH="$(type -P nohup)"
  declare gSYSTEMD_INHIBIT_PATH="$(type -P systemd-inhibit)"
  declare gBASH_PATH="$BASH"
  declare gTEE_PATH="$(type -P tee)"
  declare gLIVELOG_PATH="/dev/shm/update_live.log"
  declare gLOG_PATH="/var/log/updateall.log"
  declare gSYNC_PATH="$(type -P sync)"
  declare gRTCWAKE_PATH="$(type -P rtcwake)"
  declare gDATE_PATH="$(type -P date)"
  declare gREBOOT_REQUIRED_PATH="/var/run/reboot-required"
  declare gSHUTDOWN_PATH="$(type -P shutdown)"
  declare gAPT_GET_PATH="$(type -P apt-get)"
  declare gDNF_PATH="$(type -P dnf)"
  declare gZYPPER_PATH="$(type -P zypper)"
  declare gRUNUSER_PATH=$(type -P runuser)
  declare gFLATPAK_PATH="$(type -P flatpak)"
  declare gAWK_PATH=$(type -P awk)
  declare gSNAP_PATH="$(type -P snap)"


  updatingall() {
    declare -i lTIMEOUT=1
    declare lWHEN="$1"
    declare lDELAY="${2:-0}"
    declare lSKIP="${3:-}";
    declare lPASSWD_FILE="/etc/passwd"
    declare lUSERNAME=""
    declare lUID=""
    declare lHOME_DIR=""
    declare lFLATPAK_DIR=""
    declare lDISTRO_ID=""
    declare lREBOOT=0

    needs_reboot() {
      declare lRESULT=0

      if [ -n "$gAPT_GET_PATH" ] && [ -f "$gREBOOT_REQUIRED_PATH" ]; then
        (( lRESULT |= 1 ))
      fi

      if [ -n "$gDNF_PATH" ]; then
        "$gDNF_PATH" needs-restarting -r
        (( lRESULT |= ( $? == 1 ) ))
      fi

      if [ -n "$gZYPPER_PATH" ]; then
        "$gZYPPER_PATH" needs-rebooting
        (( lRESULT |= ( $? == 103 ) ))
      fi

      if (( lRESULT )); then
        return 1
      fi

      return 0
    }

    if [ -n "$lDELAY" ]; then
      sleep "$lDELAY"
    fi

    if [ -n "$lWHEN" ]; then
      echo "$($gDATE_PATH '+%Y-%m-%d %H:%M:%S') updateall set rtcwake $lWHEN and exec with a $lDELAY second delay and $([ -z "$lSKIP" ] && echo "not ")skipping updates." | "$gTEE_PATH" -a "$gLOG_PATH" ; \
        "$gSYNC_PATH" ; \
        "$gRTCWAKE_PATH" -m no -u -t $("$gDATE_PATH" -d "$lWHEN" +%s)
    else
      echo "$($gDATE_PATH '+%Y-%m-%d %H:%M:%S') updateall" >> "$gLOG_PATH"
      echo "updateall (bare manual run)"
    fi

    needs_reboot
    (( lREBOOT |= $? == 1 ))

    if (( lREBOOT )); then
      "$gSHUTDOWN_PATH" -r +$lTIMEOUT "System will reboot for maintenance in $lTIMEOUT minutes"

    elif [ -z "$lSKIP" ]; then

      if [ -n "$lWHEN" ] && [ -n "$gSCRIPT_PREFLIGHT" ] \
          && [ -f "$gSCRIPT_PREFLIGHT" ] \
              && [ -r "$gSCRIPT_PREFLIGHT" ] \
                  && [ ! -x "$gSCRIPT_PREFLIGHT" ]; then
        "${BASH:-:}" "$gSCRIPT_PREFLIGHT"
      fi

      if [ -n "$gAPT_GET_PATH" ]; then
        echo "--- Starting APT Update Chain ---"
        "$gAPT_GET_PATH" -yqq update && "$gAPT_GET_PATH" -yqq full-upgrade && "$gAPT_GET_PATH" -yqq autoremove 2>&1
      fi

      if [ -n "$gDNF_PATH" ]; then
        lDISTRO_ID=$("$gAWK_PATH" -F= '/^ID=/ {gsub(/"/, "", $2); print $2}' /etc/os-release)
        case "$lDISTRO_ID" in
          "openmandriva")
            echo "--- Starting OpenMandriva DNF Update Chain ---"

            "$gDNF_PATH" clean all # Going once...
            "$gDNF_PATH" clean all # Going twice...
            "$gDNF_PATH" repolist
            "$gDNF_PATH" distro-sync --refresh --allowerasing -y
            ;;
          *)
            echo "--- Starting Generic DNF Update Chain ---"
            "$gDNF_PATH" upgrade --refresh -y
            ;;
        esac
      fi

      if [ -n "$gZYPPER_PATH" ]; then
        echo "--- Starting openSUSE Zypper Update Chain ---"

        lDISTRO_ID=$("$gAWK_PATH" -F= '/^ID=/ {gsub(/"/, "", $2); print $2}' /etc/os-release)
        case "$lDISTRO_ID" in
          "opensuse-tumbleweed"|"opensuse-slowroll")
            "$gZYPPER_PATH" --non-interactive dist-upgrade
            ;;
          "opensuse-leap")
            "$gZYPPER_PATH" --non-interactive update
            ;;
        esac
      fi

      if [ -n "$gFLATPAK_PATH" ]; then
        echo "--- Starting Flatpak Update Chain ---"

          echo "-- Updating system-wide"

          ( "$gFLATPAK_PATH" -y --noninteractive update &&
            "$gFLATPAK_PATH" -y --noninteractive uninstall --unused ) 2>&1 | "$gAWK_PATH" 'NF {p=1} p'

          echo "-- Updating user-wide"

          while IFS=: read -r lUSERNAME _ lUID _ _ lHOME_DIR _; do

            if [ "$lUID" -lt 1000 ] || [ "$lUID" -eq 65534 ]; then
              continue
            fi

            lFLATPAK_DIR="$lHOME_DIR/.local/share/flatpak"

            if [ -d "$lFLATPAK_DIR" ]; then
              ((lUSER_COUNT+=1))
              echo "- Updating Flatpaks for User $lUSER_COUNT"

              ( DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/$lUID/bus" "$gRUNUSER_PATH" -l "$lUSERNAME" -c \
                  "\"$gFLATPAK_PATH\" --user -y --noninteractive update" &&
                DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/$lUID/bus" "$gRUNUSER_PATH" -l "$lUSERNAME" -c \
                    "\"$gFLATPAK_PATH\" --user -y --noninteractive uninstall --unused" ) 2>&1 | "$gAWK_PATH" 'NF {p=1} p'
            fi

          done < "$lPASSWD_FILE"
        fi

      if [ -n "$gSNAP_PATH" ]; then
        echo "--- Starting Snap Refresh ---"
        "$gSNAP_PATH" refresh
      fi

      needs_reboot
      (( lREBOOT |= $? == 1  ))

      if (( lREBOOT )); then
        "$gSHUTDOWN_PATH" -r +$lTIMEOUT "System will reboot for maintenance in $lTIMEOUT minutes"
      fi
    fi

    exit 0
  }

  validate_boot_window() {
    # Categorized Declarations (Grouped and initialized at the very top)
    declare lMAX_UPTIME_WINDOW=$((10 * 60))                   # Max allowed system uptime bound
    declare lOFFSET=$((5 * 60))                               # Target calibration math shift size

    declare lGREP_PATH="" lUPTIME_PATH=""                     # Binary paths
    declare lBOOT=0 lTARGET=0 lUP=0 lDIFF=0                   # Math and time metrics
    declare lNOW=0                                            # Current system epoch tracker

    # Synchronize Parameter 2 (Delay): Defaults strictly to an empty string if omitted
    gDELAY="${2:-${lDELAY:-""}}"

    # Synchronize Parameter 3 (Skip Check): Check command line argument first, fallback to cron env
    gSKIPUD="${3:-${lSKIPUD:+yes}}"

    # USE CASE CHECK: If $1 is totally empty (Bare Manual), skip everything cleanly
    [ -z "$1" ] && return 0

    # Dynamically resolve absolute paths using type -P
    lSED_PATH=$(type -P sed)
    lGREP_PATH=$(type -P grep)
    lUPTIME_PATH=$(type -P uptime)

    # Track current timestamp epoch metrics
    lNOW=$($gDATE_PATH +%s)

    # Clean the input string to protect GNU date from formatting artifacts
    declare lPARSED_INPUT="$1"

    # Extract the raw HH:MM clock pattern, supporting both padded and single-digit minutes (e.g., "10:5")
    declare lEXTRACTED_TIME=""
    lEXTRACTED_TIME=$(echo "$lPARSED_INPUT" | $lGREP_PATH -oE '[0-9]{1,2}:[0-9]{1,2}')

    if [ -n "$lEXTRACTED_TIME" ]; then
      # Internal Bash padding logic to fix single-digit hour/minute fields without using sprintf
      declare lHR="${lEXTRACTED_TIME%:*}"
      declare lMIN="${lEXTRACTED_TIME#*:}"
      [ ${#lHR} -eq 1 ] && lHR="0$lHR"
      [ ${#lMIN} -eq 1 ] && lMIN="0$lMIN"
      declare lPADDED_TIME="$lHR:$lMIN"

      # Reconstruct the string with the freshly padded time format
      lPARSED_INPUT=$(echo "$lPARSED_INPUT" | "$lSED_PATH" "s/$lEXTRACTED_TIME/$lPADDED_TIME/")

      # If the string contains "tomorrow", explicitly preserve that timeline shift direction cleanly
      if echo "$lPARSED_INPUT" | $lGREP_PATH -q "tomorrow"; then
        lTARGET=$($gDATE_PATH -d "tomorrow $lPADDED_TIME" +%s 2>/dev/null || return 0)
      else
        lTARGET=$($gDATE_PATH -d "today $lPADDED_TIME" +%s 2>/dev/null || return 0)
      fi
    else
      # Standard safe processing fallback for relative manual syntax like "+1 hour"
      lTARGET=$($gDATE_PATH -d "$lPARSED_INPUT" +%s 2>/dev/null || return 0)
    fi

    # Deduct your exact calibration offset (5 minutes) uniformly across all execution types
    lTARGET=$(( lTARGET - lOFFSET ))

    # Export the calibrated absolute timestamp string format for the downstream execution hooks
    gWAKEAT=$($gDATE_PATH -d "@$lTARGET" +"%Y-%m-%d %H:%M:%S")

    # Isolate total system uptime integers and target window differentials
    lUP=$($gAWK_PATH '{print int($1)}' /proc/uptime)
    lDIFF=$(( lNOW - lTARGET ))

    # Hard Block Execution: Exit ONLY the helper function loop via return to protect terminal outputs
    { [ "$lDIFF" -gt "$lMAX_UPTIME_WINDOW" ] || [ "$lUP" -le "$lMAX_UPTIME_WINDOW" ]; } && return 0
  }

  log_and_maybe_show() {
    "$gLOGGER_PATH" -t updateall
  }

  validate_boot_window "$@"

  export -f updatingall

  export \
      gLOGGER_PATH \
      gNOHUP_PATH \
      gSYSTEMD_INHIBIT_PATH \
      gBASH_PATH \
      gTEE_PATH \
      gLIVELOG_PATH \
      gLOG_PATH \
      gSYNC_PATH \
      gRTCWAKE_PATH \
      gDATE_PATH \
      gREBOOT_REQUIRED_PATH \
      gSHUTDOWN_PATH \
      gSCRIPT_PREFLIGHT \
      gAPT_GET_PATH \
      gDNF_PATH \
      gZYPPER_PATH \
      gFLATPAK_PATH \
      gRUNUSER_PATH \
      gAWK_PATH \
      gSNAP_PATH

  ( "$gNOHUP_PATH" "$gSYSTEMD_INHIBIT_PATH" \
      --why="Running updates" \
      --mode=block \
      --what=idle:sleep:shutdown:handle-power-key:handle-suspend-key:handle-hibernate-key:handle-lid-switch \
        "$gBASH_PATH" -c 'updatingall "$1" "$2" "$3" 2>&1' -- "$gWAKEAT" "$gDELAY" "$gSKIPUD" | \
            "$gTEE_PATH" "$gLIVELOG_PATH" >(log_and_maybe_show) ) > /dev/null 2>&1 &

  lPID=$!
  [ -t 1 ] && ( sleep 0.1; tail --pid=$lPID -f "$gLIVELOG_PATH" )
fi

